    "expo-font": "13.3.2",
    "expo-localization": "~16.0.1",
    "expo-speech": "~13.0.1",
    "expo-sqlite": "~15.2.14",
    "expo-status-bar": "~2.2.3",
    "fast-xml-parser": "^5.2.5",
    "lucide-react-native": "^1.7.0",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "react-native": "0.79.3",
