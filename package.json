{
  "name": "mochigo",
  "version": "0.1.2",
  "private": true,
  "engines": {
    "node": ">=20 <25"
  },
  "packageManager": "pnpm@10.33.0",
  "main": "./index.js",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "lint": "eslint . --ext .js,.ts,.tsx",
    "lint:fix": "eslint . --ext .js,.ts,.tsx --fix",
    "typecheck": "typescript-eslint .",
    "data:download": "node scripts/download-data.mjs",
    "data:build": "node scripts/build-jlpt-data.mjs",
    "data:refresh": "npm run data:download && npm run data:build",
    "build:android": "eas build -p android --profile production"
  },
  "dependencies": {
    "@expo/metro-runtime": "~55.0.0",
    "@react-native-async-storage/async-storage": "2.2.0",
    "buffer": "^6.0.3",
    "csv-parse": "^5.6.0",
    "expo": "~55.0.0",
    "expo-constants": "~55.0.0",
    "expo-dev-client": "~55.0.0",
    "expo-font": "~55.0.0",
    "expo-localization": "~55.0.0",
    "expo-speech": "~55.0.0",
    "expo-sqlite": "~55.0.0",
    "expo-status-bar": "~55.0.0",
    "fast-xml-parser": "^5.2.5",
    "lucide-react-native": "^0.474.0",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-native": "0.83.4",
    "react-native-google-mobile-ads": "^15.4.0",
    "react-native-safe-area-context": "5.6.2",
    "react-native-svg": "15.15.3",
    "react-native-web": "~0.21.0",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@anthropic-ai/sdk": "^0.81.0",
    "@babel/core": "^7.25.2",
    "@eslint/js": "^9.39.4",
    "@stylistic/eslint-plugin": "^4.4.1",
    "@types/node": "^22.13.0",
    "@types/react": "~19.2.14",
    "babel-preset-expo": "~55.0.0",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^5.2.0",
    "globals": "^16.5.0",
    "typescript": "^5.3.3",
    "typescript-eslint": "^8.5.0"
  }
}
