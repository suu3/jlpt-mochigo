    "fast-xml-parser": "^5.2.5",
    "lucide-react-native": "^1.7.0",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-native": "0.83.4",
    "react-native-google-mobile-ads": "^15.4.0",
